{
  "name": "opencode-discord",
  "private": true,
  "type": "module",
  "workspaces": [
    "opencode"
  ],
  "scripts": {
    "dev": "bun --env-file=.env src/index.ts",
    "start": "bun --env-file=.env src/index.ts",
    "typecheck:root": "tsgo -p tsconfig.json",
    "typecheck": "bun run typecheck:root && bun run --cwd opencode typecheck"
  },
  "dependencies": {
    "@discordjs/builders": "^1.13.1",
    "@effect/platform-bun": "^0.87.1",
    "@opencode-ai/sdk": "^1.2.21",
    "discord.js": "^14.25.1",
    "effect": "^3.19.19"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@typescript/native-preview": "^7.0.0-dev.20260308.1",
    "typescript": "^5.9.3"
  }
}
