DISCORD_TOKEN=your_discord_bot_token
TRIGGER_PHRASE=hey opencode
# Optional extra instructions appended to the OpenCode system prompt for each Discord channel session.
# SESSION_INSTRUCTIONS=Be concise. Prefer TypeScript when reasonable.
# Optional persistent storage root for session metadata and per-channel session homes.
# STATE_DIR=./storage
# Optional per-channel-session default model override.
# Both values must be set to apply the override; otherwise normal OpenCode defaults are used.
# DEFAULT_PROVIDER_ID=openai
# DEFAULT_MODEL_ID=gpt-5
# Optional default for whether thinking messages are shown in each channel.
# SHOW_THINKING_BY_DEFAULT=true
# Optional default for whether compaction summaries are shown in each channel.
# SHOW_COMPACTION_SUMMARIES_BY_DEFAULT=true
# Optional idle timeout before an unused per-channel OpenCode worker is closed.
# Session metadata and thread history remain persisted and are reopened lazily on the next message.
# SESSION_IDLE_TIMEOUT_MS=1800000
# Optional explicit Unix socket path for the Discord tool bridge.
# DISCORD_TOOL_BRIDGE_SOCKET=/tmp/opencode-discord/bridge.sock
SANDBOX_BACKEND=auto
OPENCODE_BIN=opencode
BWRAP_BIN=bwrap
# Optional comma-separated read-only bind list for the Linux bwrap backend.
# SANDBOX_READ_ONLY_PATHS=/usr,/bin,/lib,/lib64,/usr/local,/opt,/nix/store
# Optional comma-separated extra env vars to pass through to sandboxed workers.
# Most OpenCode/provider auth should come from the host opencode XDG state instead.
# SANDBOX_ENV_PASSTHROUGH=MY_INTERNAL_ENDPOINT
