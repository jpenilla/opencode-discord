DISCORD_TOKEN=your_discord_bot_token
TRIGGER_PHRASE=hey opencode
# Optional explicit Unix socket path for the Discord tool bridge.
# DISCORD_TOOL_BRIDGE_SOCKET=/tmp/opencode-discord/bridge.sock
SANDBOX_BACKEND=auto
OPENCODE_BIN=opencode
BWRAP_BIN=bwrap
# Optional comma-separated read-only bind list for the Linux bwrap backend.
# SANDBOX_READ_ONLY_PATHS=/usr,/bin,/lib,/lib64,/usr/local,/opt,/nix/store
# Optional comma-separated extra env vars to pass through to sandboxed workers.
# Most OpenCode/provider auth should come from the host opencode XDG state instead.
# SANDBOX_ENV_PASSTHROUGH=MY_INTERNAL_ENDPOINT
